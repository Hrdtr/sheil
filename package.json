{
  "name": "sheil",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, cross-platform SSH/telnet/serial client — a Termius alternative.",
  "author": {
    "name": "Herdi Tr."
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "fmt": "oxfmt .",
    "lint": "oxfmt --check . && oxlint .",
    "tauri": "tauri",
    "test:check": "nub run check && nub run lint",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path tauri/Cargo.toml",
    "test": "nub run test:check && nub run test:unit && nub run test:rust",
    "test:watch": "vitest",
    "prepare": "husky && echo \"nubx lint-staged\" > .husky/pre-commit && echo \"nubx commitlint --edit ${1}\" > .husky/commit-msg"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@types/node": "^26.0.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@lucide/svelte": "^1.21.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "commitlint": "^21.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "nub run lint"
  }
}
